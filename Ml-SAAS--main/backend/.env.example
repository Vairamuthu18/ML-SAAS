# ML Viz Lab Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# Server port (default: 8000)
PORT=8000

# Set to "true" only in development to enable Swagger docs and verbose logging
DEBUG=false

# Comma-separated list of allowed frontend origins for CORS
# Example: https://ml-viz-lab.vercel.app,http://localhost:8080
ALLOWED_ORIGINS=*
